generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth v5) ──────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash     String?
  name             String?
  image            String?
  isSuperAdmin       Boolean   @default(false)
  onboardedAt        DateTime?
  representativeRole String?
  marketingConsent   Boolean   @default(false)
  termsAcceptedAt    DateTime?
  failedLogins       Int       @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  companyUsers CompanyUser[]
  auditLogs    AuditLog[]
  passwordResetTokens PasswordResetToken[]
}

// ─── Audit log (кой / кога / какво) ──────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  companyId String
  userId    String?
  action    String   // create | update | delete | status_change | login | impersonate
  entity    String   // Document | Client | Expense | Company | ...
  entityId  String?
  summary   String?  @db.Text
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@index([companyId, createdAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Company / Multi-tenant ──────────────────────────────────────────────
model Company {
  id              String   @id @default(cuid())
  name            String
  eik             String?
  vatNumber       String?
  vatRegistered   Boolean  @default(false)
  address         String?
  city            String?
  mol             String?
  sector          String?
  country         String?  @default("България")
  // Business Profile & Smart Workspace
  businessSector   String?
  businessCategory String?
  companySize      String?
  dashboardLayout  String?  @db.Text
  isCustomLayout   Boolean  @default(false)
  logoUrl         String?
  brandColor      String?
  defaultCurrency String   @default("EUR")
  defaultLanguage String   @default("bg")
  invoiceTemplate String   @default("classic")
  bankIban        String?
  bankName        String?
  bankBic         String?
  phone           String?
  email           String?
  website         String?
  // Per-type number start values (next number = max(start, count)+1)
  invoiceNumberStart Int   @default(1)
  // ДДС настройки по подразбиране
  defaultVatExempt       Boolean @default(false) // по подразбиране не начислявай ДДС
  defaultVatExemptReason String?                 // основание по подразбиране (код)
  // JSON map of email-automation preferences (which automated emails the company receives)
  emailPrefs      String?  @db.Text
  // JSON конфиг какви модули виждат служителите (роля employee): { projects, clients, suppliers, warehouse }
  employeeAccess  String?  @db.Text
  // Меко изтриване (архив) от Супер Админ — фирмата се скрива, но данните се пазят.
  archivedAt      DateTime?
  // Откъде е дошла регистрацията (напр. "invoice_portal" — клиент, получил фактура)
  referralSource  String?
  // Споделяне на документи към други регистрирани фирми през платформата (по подразбиране включено)
  shareDocsInternally Boolean @default(true)
  // ─── Счетоводна къща (мулти-фирмен режим за счетоводители) ───
  isAccountingFirm Boolean @default(false) // тази фирма е счетоводна къща/кантора
  firmPlan         String?                 // абонаментен тир за счетоводна къща (acc_solo | acc_office | acc_house)
  managedByFirmId  String?                 // ако е клиентска фирма — коя счетоводна къща я управлява
  createdAt       DateTime @default(now())

  auditLogs         AuditLog[]
  cashRegisters     CashRegister[]
  bankStatements    BankStatement[]

  companyUsers      CompanyUser[]
  clients           Client[]
  suppliers         Supplier[]
  warehouses        Warehouse[]
  stockItems        StockItem[]
  documents         Document[]
  expenseCategories ExpenseCategory[]
  expenses          Expense[]
  contracts         Contract[]
  projects          Project[]
  assets            Asset[]
  subscription      Subscription?
  usageCounters     UsageCounter[]
  financialGoals    FinancialGoal[]
  financialHistory  FinancialHistory[]
  handoverProtocols HandoverProtocol[]
  archiveFiles      ArchiveFile[]
  stockCategories   StockCategory[]
  recipes           Recipe[]
  employees         Employee[]
  technologicalDocs TechnologicalDoc[]
  conformityDeclarations ConformityDeclaration[]
  stocktakes        Stocktake[]
  taxReminders      TaxReminder[]
  businessDocuments BusinessDocument[]
  subscriptionEvents SubscriptionEvent[]
  payrollMonths     PayrollMonth[]
  monthlyEntries    MonthlyEntry[]
  projectBoards     ProjectBoard[]
  projectTasks      ProjectTask[]

  // Самореференция: счетоводна къща ↔ управлявани клиентски фирми
  managingFirm      Company?  @relation("FirmClients", fields: [managedByFirmId], references: [id], onDelete: SetNull)
  managedClients    Company[] @relation("FirmClients")

  @@index([managedByFirmId])
  @@index([isAccountingFirm])
}

// История на абонаментите (заявки, плащания, промени на статус/план)
model SubscriptionEvent {
  id        String   @id @default(cuid())
  companyId String
  type      String   // request | payment | plan_change | status_change | trial | expiry
  plan      String?
  status    String?
  period    String?
  amount    Float?
  note      String?
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
}

enum CompanyRole {
  owner
  manager
  accountant
  sales
  warehouse
  viewer
  employee
}

model CompanyUser {
  userId    String
  companyId String
  role      CompanyRole @default(viewer)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([userId, companyId])
}

// ─── CRM ─────────────────────────────────────────────────────────────────
model Client {
  id            String   @id @default(cuid())
  companyId     String
  name          String
  eik           String?
  vatNumber     String?
  address       String?
  city          String?
  mol           String?
  contactPerson String?
  contactEmail  String?
  phone         String?
  // CRM
  status        String   @default("active") // lead | active | vip | inactive | lost
  stage         String   @default("new")    // pipeline: new | contacted | proposal | negotiation | won | lost
  dealValue     Float?
  birthday      DateTime?
  website       String?
  tags          String?  // CSV
  // От коя дата се работи с клиента + пренесен оборот със задна дата (миграция от друга система)
  clientSince   DateTime?
  openingRevenue Float?  @default(0)
  // Абонаментен договор (по избор) — очаквани месечни приходи
  monthlyRetainer Float?
  createdAt     DateTime @default(now())

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  notes     ClientNote[]
  documents Document[]
  contracts Contract[]
  projects  Project[]
  contacts  ClientContact[]
  tasks     ClientTask[]
  files     ClientFile[]
}

model ClientContact {
  id        String  @id @default(cuid())
  clientId  String
  name      String
  position  String?
  phone     String?
  email     String?
  isPrimary Boolean @default(false)

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientTask {
  id        String    @id @default(cuid())
  clientId  String
  title     String
  type      String?   // call | email | offer | contract | followup | meeting | other
  dueDate   DateTime?
  done      Boolean   @default(false)
  createdAt DateTime  @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, done])
}

model ClientFile {
  id         String   @id @default(cuid())
  clientId   String
  name       String
  mimeType   String
  size       Int
  dataUrl    String   @db.Text
  uploadedAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientNote {
  id        String   @id @default(cuid())
  clientId  String
  note      String   @db.Text
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// ─── Suppliers ───────────────────────────────────────────────────────────
model Supplier {
  id           String   @id @default(cuid())
  companyId    String
  name         String
  eik          String?
  vatNumber    String?
  address      String?
  city         String?
  contactPerson String?
  contactEmail String?
  phone        String?
  website      String?
  rating       Int?
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockMovements    StockMovement[]
  expenses          Expense[]
  supplierDocuments SupplierDocument[]
  contracts         Contract[]
}

model SupplierDocument {
  id         String @id @default(cuid())
  supplierId String
  fileUrl    String
  type       String

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
}

// ─── Warehouse ───────────────────────────────────────────────────────────
model Warehouse {
  id        String @id @default(cuid())
  companyId String
  name      String

  company    Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stockItems StockItem[]
}

model StockItem {
  id          String  @id @default(cuid())
  companyId   String
  warehouseId String
  categoryId  String?
  name        String
  sku         String?
  quantity    Float   @default(0)
  minQuantity Float?
  unit        String  @default("бр")
  unitCost    Float?
  expiryDate  DateTime?  // null = безсрочно

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouse Warehouse       @relation(fields: [warehouseId], references: [id])
  category  StockCategory?  @relation(fields: [categoryId], references: [id])
  movements StockMovement[]
  batches   StockBatch[]
}

model StockCategory {
  id        String @id @default(cuid())
  companyId String
  name      String
  parentId  String?

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent  StockCategory?  @relation("CategoryTree", fields: [parentId], references: [id])
  children StockCategory[] @relation("CategoryTree")
  items   StockItem[]
}

model StockBatch {
  id          String   @id @default(cuid())
  stockItemId String
  batchNumber String
  quantity    Float    @default(0)
  unitCost    Float?
  note        String?
  createdAt   DateTime @default(now())

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@index([stockItemId, createdAt])
}

// Рецепти за производство
model Recipe {
  id             String       @id @default(cuid())
  companyId      String
  name           String
  outputItemId   String?
  outputQuantity Float        @default(1)
  note           String?      @db.Text
  createdAt      DateTime     @default(now())

  company     Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  ingredients RecipeItem[]
}

model RecipeItem {
  id          String @id @default(cuid())
  recipeId    String
  stockItemId String
  quantity    Float

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
}

// Служители
model Employee {
  id             String   @id @default(cuid())
  companyId      String
  name           String
  position       String?
  phone          String?
  email          String?
  address        String?
  salary         Float?
  hiredAt        DateTime?
  paidLeaveDays  Int      @default(20) // годишен платен отпуск (мин. по закон 20 раб. дни)
  active         Boolean  @default(true)
  notes          String?  @db.Text
  // Разширени данни
  department     String?  // отдел / звено
  contractType   String?  // permanent | fixed_term | civil
  paymentMethod  String   @default("bank") // bank | cash
  iban           String?  // банкова сметка за заплата
  bankName       String?
  userId         String?  @unique // свързан потребителски акаунт (self-service портал)
  createdAt      DateTime @default(now())

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  leaves  EmployeeLeave[]
  files   EmployeeFile[]
  bonuses EmployeeBonus[]
}

// Бонуси на служител — по месец, със сума, вид и бележка
model EmployeeBonus {
  id         String   @id @default(cuid())
  employeeId String
  year       Int
  month      Int      // 0-11
  amount     Float
  kind       String   @default("cash") // cash | voucher | performance | holiday | other
  note       String?
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model EmployeeFile {
  id         String   @id @default(cuid())
  employeeId String
  name       String
  docType    String?  // трудов договор | молба за отпуск | допълнително споразумение | ...
  mimeType   String
  size       Int
  dataUrl    String   @db.Text
  uploadedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// Месечна корекция на разхода за заплати (отпуски, болнични, бонуси, промяна на заплата)
model PayrollMonth {
  id        String   @id @default(cuid())
  companyId String
  year      Int
  month     Int      // 0-11
  amount    Float    // общ разход за работодателя за месеца (коригиран)
  note      String?
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, year, month])
}

// Ръчно въведени месечни приходи/разходи (за прехвърляне назад в текущата година)
model MonthlyEntry {
  id        String   @id @default(cuid())
  companyId String
  year      Int
  month     Int      // 0-11
  revenue   Float    @default(0)
  expenses  Float    @default(0)
  note      String?
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, year, month])
}

model EmployeeLeave {
  id          String   @id @default(cuid())
  employeeId  String
  type        String   // leave | sick | unpaid | other
  startDate   DateTime
  endDate     DateTime
  days        Float?
  note        String?
  docName     String?  // прикачен документ (молба, болничен лист и т.н.)
  docMimeType String?
  docDataUrl  String?  @db.Text
  // Работен поток на заявките за отпуск от служителя
  status              String   @default("approved") // pending | approved | rejected
  requestedByEmployee Boolean  @default(false)
  reviewedAt          DateTime?
  reviewNote          String?
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

// HACCP — Технологична документация
model TechnologicalDoc {
  id          String   @id @default(cuid())
  companyId   String
  docNumber   String?
  productName String
  purpose     String?  @db.Text
  classification String? @db.Text
  ingredients String?  @db.Text
  rawMaterials String? @db.Text
  packaging   String?  @db.Text
  preparation String?  @db.Text
  process     String?  @db.Text
  bakingTime  String?
  bakingTemp  String?
  cooling     String?
  organoleptic String? @db.Text
  physicochemical String? @db.Text
  microbiological String? @db.Text
  samplingMethods String? @db.Text
  labeling    String?  @db.Text
  storage     String?
  storageConditions String?
  transport   String?
  shelfLife   String?
  productionControl String? @db.Text
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// Декларация за съответствие
model ConformityDeclaration {
  id           String   @id @default(cuid())
  companyId    String
  number       String
  // Клиент (получател)
  clientName    String?
  clientEik     String?
  clientAddress String?
  clientMol     String?
  products      String?  @db.Text // JSON: [{name, kg, batch, bestBefore}]
  labResults    String?  @db.Text // JSON: [{indicator, method, result}]
  declarationText String? @db.Text
  storageNote   String?
  standards    String?  @db.Text
  description  String?  @db.Text
  productName  String?
  batchNumber  String?
  issuedFor    String?
  date         DateTime
  signedBy     String?
  createdAt    DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// Ревизия (инвентаризация)
model Stocktake {
  id        String          @id @default(cuid())
  companyId String
  userId    String?         // кой е направил ревизията
  date      DateTime        @default(now())
  note      String?
  status    String          @default("applied") // draft | applied
  createdAt DateTime        @default(now())

  company Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines   StocktakeLine[]
}

model StocktakeLine {
  id          String @id @default(cuid())
  stocktakeId String
  stockItemId String
  itemName    String
  previousQty Float
  countedQty  Float

  stocktake Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
}

// Данъчни напомняния (календар)
model TaxReminder {
  id        String   @id @default(cuid())
  companyId String
  title     String
  dueDate   DateTime
  done      Boolean  @default(false)
  priority  String   @default("normal") // low | normal | high
  progress  Int      @default(0)        // 0-100 % изпълнение
  note      String?  @db.Text
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum StockMovementType {
  receive
  issue
  production
  transfer
  scrap
  stocktake
  packaging
  sale
}

model StockMovement {
  id          String            @id @default(cuid())
  stockItemId String
  type        StockMovementType
  quantity    Float
  supplierId  String?
  unitPrice   Float?
  date        DateTime
  note        String?

  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  supplier  Supplier? @relation(fields: [supplierId], references: [id])
}

// ─── Documents ───────────────────────────────────────────────────────────
enum DocumentType {
  invoice
  proforma
  quote
  credit_note
  debit_note
}

enum DocumentStatus {
  draft
  issued
  sent
  partially_paid
  paid
  overdue
  cancelled
}

model Document {
  id                 String         @id @default(cuid())
  companyId          String
  type               DocumentType
  number             String
  clientId           String?
  issueDate          DateTime
  taxEventDate       DateTime?
  dueDate            DateTime?
  currency           String         @default("EUR")
  language           String         @default("bg")
  template           String         @default("classic")
  paymentMethod      String         @default("bank_transfer")
  paidAmount         Float          @default(0)
  status             DocumentStatus @default(draft)
  isRecurring        Boolean        @default(false)
  recurrenceInterval String?
  parentDocumentId   String?
  notes              String?        @db.Text
  internalComment    String?        @db.Text
  // ДДС освобождаване (за конкретната фактура)
  vatExempt          Boolean        @default(false)
  vatExemptReason    String?        // код/текст на основанието
  clientIsIndividual Boolean        @default(false) // получателят е физическо лице (без ЕИК/ДДС)
  // External client sharing (email + accept/reject portal)
  clientEmail        String?
  publicToken        String?        @unique
  clientDecision     String?        // accepted | rejected
  clientDecisionAt   DateTime?
  sentToClientAt     DateTime?
  // Inter-company sharing — ако получателят е регистрирана фирма в платформата
  recipientCompanyId String?
  createdAt          DateTime       @default(now())

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client         Client?        @relation(fields: [clientId], references: [id])
  parentDocument Document?      @relation("DocumentChain", fields: [parentDocumentId], references: [id])
  childDocuments Document[]     @relation("DocumentChain")
  lines          DocumentLine[]

  @@index([recipientCompanyId])
}

// In-app нотификации (вкл. получени документи между фирми)
model Notification {
  id        String   @id @default(cuid())
  companyId String
  type      String   // incoming_document | system | info
  title     String
  body      String?  @db.Text
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([companyId, read])
}

model DocumentLine {
  id               String  @id @default(cuid())
  documentId       String
  description      String
  quantity         Float
  unitPrice        Float
  vatRate          Float   @default(20)
  lineTotal        Float
  nomenclatureCode String?

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

// ─── Expenses ────────────────────────────────────────────────────────────
model ExpenseCategory {
  id        String  @id @default(cuid())
  companyId String?
  name      String
  isCustom  Boolean @default(false)

  company  Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses Expense[]
}

enum ExpenseSource {
  manual
  incoming_invoice
}

model Expense {
  id            String        @id @default(cuid())
  companyId     String
  categoryId    String
  supplierId    String?
  description   String
  invoiceNumber String?
  amount        Float
  vatAmount     Float         @default(0)
  date          DateTime
  source        ExpenseSource @default(manual)
  attachmentUrl String?
  isRecurring   Boolean       @default(false) // повтарящ се месечен разход (наем, заплати…)
  createdAt     DateTime      @default(now())

  company  Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  supplier Supplier?       @relation(fields: [supplierId], references: [id])
}

// ─── Contracts ───────────────────────────────────────────────────────────
enum ContractCounterpartyType {
  client
  supplier
}

enum ContractStatus {
  active
  expired
  cancelled
}

model Contract {
  id               String                   @id @default(cuid())
  companyId        String
  title            String
  counterpartyType ContractCounterpartyType
  clientId         String?
  supplierId       String?
  startDate        DateTime
  endDate          DateTime?
  autoRenew        Boolean                  @default(false)
  status           ContractStatus           @default(active)
  value            Float?
  notes            String?                  @db.Text
  attachmentUrl    String?                  @db.Text

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client   Client?   @relation(fields: [clientId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
}

// ─── Projects ────────────────────────────────────────────────────────────
enum ProjectStatus {
  active
  completed
  on_hold
  cancelled
}

enum ProjectEntryType {
  revenue
  expense
}

model Project {
  id                String        @id @default(cuid())
  companyId         String
  name              String
  description       String?       @db.Text
  clientId          String?
  responsibleUserId String?
  budget            Float?
  plannedBudget     Float?
  actualSpent       Float         @default(0)
  status            ProjectStatus @default(active)
  deadline          DateTime?
  progressPercent   Int           @default(0)
  parentProjectId   String?
  createdAt         DateTime      @default(now())

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client  Client?        @relation(fields: [clientId], references: [id])
  entries ProjectEntry[]
  files   ProjectFile[]
  notes   ProjectNote[]
  parentProject Project?  @relation("ProjectTree", fields: [parentProjectId], references: [id])
  subProjects   Project[] @relation("ProjectTree")

  @@index([parentProjectId])
}

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  note      String   @db.Text
  author    String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectEntry {
  id          String           @id @default(cuid())
  projectId   String
  refType     String           @default("manual")
  refId       String?
  description String?
  amount      Float
  type        ProjectEntryType
  date        DateTime         @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectFile {
  id        String  @id @default(cuid())
  projectId String
  fileUrl   String
  name      String?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

// ─── Assets ──────────────────────────────────────────────────────────────
model Asset {
  id                 String    @id @default(cuid())
  companyId          String
  name               String
  category           String
  acquiredDate       DateTime
  value              Float
  annualDepreciation Float     @default(0)
  bookValue          Float
  warrantyUntil      DateTime?
  insuranceUntil     DateTime?
  status             String    @default("in_use") // in_use | maintenance | sold | scrapped | written_off
  notes              String?   @db.Text

  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  serviceLogs AssetServiceLog[]
}

model AssetServiceLog {
  id          String   @id @default(cuid())
  assetId     String
  date        DateTime
  description String

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
}

// ─── Handover Protocols ──────────────────────────────────────────────────
model HandoverProtocol {
  id             String   @id @default(cuid())
  companyId      String
  number         String
  counterpartyId String?
  // Свободни данни на приемащата страна
  counterpartyName    String?
  counterpartyEik     String?
  counterpartyAddress String?
  counterpartyMol     String?
  place          String?
  handedBy       String?
  receivedBy     String?
  items          String?  @db.Text
  date           DateTime
  description    String?  @db.Text
  createdAt      DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Посещения на сайта (за статистика в админ панела) ───────────────────
model SiteVisit {
  id        String   @id @default(cuid())
  visitorId String
  path      String
  area      String   @default("public") // public | app
  userId    String?
  companyId String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([visitorId])
}

// Модул „Бизнес документи" — генерирани от шаблони документи (DMS)
model BusinessDocument {
  id              String   @id @default(cuid())
  companyId       String
  templateId      String
  templateVersion Int      @default(1)
  category        String
  title           String
  contentHtml     String   @db.Text
  status          String   @default("draft") // draft | final | archived
  favorite        Boolean  @default(false)
  pinned          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, updatedAt])
}

model ArchiveFile {
  id         String   @id @default(cuid())
  companyId  String
  name       String
  category   String?
  mimeType   String
  size       Int
  dataUrl    String   @db.Text
  uploadedAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Каса (cash registers) ───────────────────────────────────────────────
model CashRegister {
  id        String   @id @default(cuid())
  companyId String
  name      String
  currency  String   @default("EUR")
  balance   Float    @default(0)
  createdAt DateTime @default(now())

  company Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  entries CashEntry[]
}

enum CashEntryType {
  in
  out
  adjust
}

model CashEntry {
  id         String        @id @default(cuid())
  registerId String
  type       CashEntryType
  amount     Float
  note       String?
  date       DateTime      @default(now())
  createdAt  DateTime      @default(now())

  register CashRegister @relation(fields: [registerId], references: [id], onDelete: Cascade)
}

// ─── Банкови извлечения ──────────────────────────────────────────────────
model BankStatement {
  id         String   @id @default(cuid())
  companyId  String
  name       String
  fileUrl    String   @db.Text // data URL (PDF/Excel/CSV)
  fileType   String   // pdf | excel | csv
  periodFrom DateTime?
  periodTo   DateTime?
  note       String?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Subscriptions / Billing ─────────────────────────────────────────────
enum SubscriptionPlan {
  free
  start
  business
  pro
}

enum SubscriptionStatus {
  active
  cancelled
  past_due
  trialing
}

model Subscription {
  id                   String             @id @default(cuid())
  companyId            String             @unique
  plan                 SubscriptionPlan   @default(free)
  status               SubscriptionStatus @default(active)
  // Ръчно потвърждение от Супер Админ за реално получено плащане.
  // Само „received" се отчита като продаден абонамент в статистиките (MRR/ARR).
  paymentStatus        PaymentStatus      @default(pending)
  stripeSubscriptionId String?
  stripeCustomerId     String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  trialUsed            Boolean            @default(false)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

enum PaymentStatus {
  received      // Получено плащане
  pending       // Изчаква се плащане
  not_received  // Не е получено плащане
}

model UsageCounter {
  companyId            String
  yearMonth            String
  documentsIssuedCount Int    @default(0)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@id([companyId, yearMonth])
}

// ─── Analytics ───────────────────────────────────────────────────────────
model FinancialGoal {
  id            String @id @default(cuid())
  companyId     String
  year          Int
  targetRevenue Float

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, year])
}

model FinancialHistory {
  id            String @id @default(cuid())
  companyId     String
  year          Int
  revenue       Float
  expenses      Float?
  profit        Float?
  employeeCount Int?

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, year])
}

// ─────────────────────────────────────────────────────────────
// Email automation: log, blacklist, password reset, trainings
// ─────────────────────────────────────────────────────────────

model EmailLog {
  id          String    @id @default(cuid())
  companyId   String?   // null = platform/admin email
  toEmail     String
  toName      String?
  category    String    @default("system") // account | subscription | document | reminder | admin | system
  type        String    // machine key, e.g. "welcome", "password_reset"
  subject     String
  status      String    @default("queued") // queued | sent | failed | skipped
  error       String?   @db.Text
  attempts    Int       @default(0)
  nextRetryAt DateTime?
  opensCount  Int       @default(0)
  openedAt    DateTime?
  clicksCount Int       @default(0)
  clickedAt   DateTime?
  bounced     Boolean   @default(false)
  scheduledFor DateTime?
  createdAt   DateTime  @default(now())
  sentAt      DateTime?

  @@index([companyId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model EmailBlacklist {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String?
  bounces   Int      @default(0)
  unsubscribed Boolean @default(false)
  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TrainingVideo {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  category    String?
  videoUrl    String?
  thumbnail   String?  @db.Text
  duration    String?
  order       Int      @default(0)
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([category])
}

// ─────────────────────────────────────────────────────────────
// Блог (SEO) — публични статии, управлявани от Супер Админ
// ─────────────────────────────────────────────────────────────
model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String?   @db.Text
  content         String    @db.Text          // HTML съдържание (снимки/видеа/линкове)
  coverImage      String?   @db.Text          // URL или base64 data URL
  author          String    @default("Екипът на Creative Digital Accounting")
  category        String?
  tags            String?                       // CSV
  // SEO
  metaTitle       String?
  metaDescription String?   @db.Text
  keywords        String?   @db.Text
  published       Boolean   @default(false)  // = (status == "published"), за съвместимост
  status          String    @default("draft") // draft | published | hidden
  publishedAt     DateTime?
  views           Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

// ─────────────────────────────────────────────────────────────
// Project Management — задачи по фирми (табла), вкл. ежемесечни
// ─────────────────────────────────────────────────────────────
model ProjectBoard {
  id             String   @id @default(cuid())
  companyId      String
  clientId       String?  // по избор — свързан клиент от CRM
  name           String   // име на фирмата/колоната
  importantNotes String?  @db.Text // важни изисквания за фирмата
  links          String?  @db.Text // JSON: { site, facebook, instagram, linkedin, google, tiktok, viber, youtube, other }
  color          String?  // акцентен цвят на колоната
  order          Int      @default(0)
  archived       Boolean  @default(false)
  createdAt      DateTime @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks   ProjectTask[]

  @@index([companyId])
}

model ProjectTask {
  id         String   @id @default(cuid())
  companyId  String
  boardId    String
  title      String
  description String?  @db.Text // описание на задачата
  notes      String?  @db.Text // бележки
  priority   String   @default("normal") // low | normal | high | urgent
  status     String   @default("pending") // pending | assigned | in_progress | review | returned | done
  progress   Int      @default(0) // 0-100
  assigneeId String?  // userId на изпълнителя (CompanyUser)
  assigneeName String? // ръчно въведено име на изпълнител (когато не е служител)
  dueDate    DateTime?
  links      String?  @db.Text // JSON: [{ label, url }]
  monthly    Boolean  @default(false) // ежемесечна (повтаряема) задача
  period     String?  // за ежемесечни: "YYYY-MM" — за кой месец се отнася
  archived   Boolean  @default(false) // приключените се архивират автоматично
  archivedAt DateTime? // кога е архивирана (за справки по месеци/години)
  order      Int      @default(0)
  createdById String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  board   ProjectBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([companyId, boardId])
  @@index([boardId, monthly])
  @@index([boardId, archived])
}
